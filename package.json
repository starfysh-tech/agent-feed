{
  "name": "agent-feed",
  "type": "module",
  "version": "0.1.0",
  "description": "Transparent proxy that captures coding agent responses and documents decisions",
  "main": "src/index.js",
  "bin": {
    "agent-feed": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "dev:ui": "cd src/ui/frontend && npm run dev",
    "build:ui": "cd src/ui/frontend && npm run build"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "better-sqlite3": "^9.4.3",
    "http-proxy": "^1.18.1",
    "https-proxy-agent": "^7.0.4",
    "node-forge": "^1.3.1",
    "sql.js": "^1.14.1",
    "toml": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
